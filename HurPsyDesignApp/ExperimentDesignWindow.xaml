<Window x:Class="HurPsyDesignApp.ExperimentDesignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HurPsyDesignApp"
        xmlns:prop="clr-namespace:HurPsyDesignApp.Properties"
        mc:Ignorable="d"
        Title="HurPsy Experiment Design Application"
        FontSize="20" Height="450" Width="800"
        WindowState="Maximized"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="StyleDefinitions.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Background="{StaticResource EdgeBrush}">
        <Expander x:Name="StimulusObjectsPanel"
                  DockPanel.Dock="Left"
                  Background="{StaticResource StimulusObjectsPanelBrush}"
                  Margin="{StaticResource EdgeThickness}"
                  Header="Stimulus Objects"
                  Style="{StaticResource RightExpander}"
                  MaxWidth="{StaticResource Expander1Width}"
                  ExpandDirection="Right"
                  IsExpanded="True">

            <Expander.Content>
                <Grid Background="AliceBlue" />
            </Expander.Content>
        </Expander>

        <Expander x:Name="StimulusRegionsPanel"
                  DockPanel.Dock="Left"
                  Background="{StaticResource StimulusRegionsPanelBrush}"
                  Margin="{StaticResource EdgeThickness}"
                  Style="{StaticResource RightExpander}"
                  MaxWidth="{StaticResource Expander2Width}"
                  ExpandDirection="Right"
                  IsExpanded="True">

            <Expander.Header>
                <TextBlock   Text="Stimulus Regions" />
            </Expander.Header>

            <Expander.Content>
                <Grid Background="AliceBlue"/>
            </Expander.Content>
        </Expander>

        <Grid x:Name="DesignGrid"
              Margin="{StaticResource EdgeThickness}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource DesignPanelWidth}" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1"
                 Background="{StaticResource EdgeBrush}"
                 Width="{StaticResource SplitterWidth}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Stretch"
                 ResizeDirection="Columns" />

            <Rectangle Grid.Column="0" Fill="{StaticResource DesignPanelBrush}"/>
            <Rectangle Grid.Column="2" Fill="{StaticResource PreviewPanelBrush}"/>
        </Grid>

    </DockPanel>
</Window>
