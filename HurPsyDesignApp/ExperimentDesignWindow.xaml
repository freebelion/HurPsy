<Window x:Class="HurPsyDesignApp.ExperimentDesignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HurPsyDesignApp"
        mc:Ignorable="d"
        Title="HurPsy Experiment Design Application"
        FontSize="20" Height="640" Width="1024"
        WindowState="Maximized"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="StyleDefinitions.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{StaticResource EdgeBrush}" BorderThickness="{StaticResource EdgeThickness}">
        <Grid x:Name="mainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding Source={StaticResource PanelWidth}}" />
                <ColumnDefinition Width="{Binding Source={StaticResource SplitterWidth}}" />
                <ColumnDefinition Width="{Binding Source={StaticResource PanelWidth}}" />
                <ColumnDefinition Width="{Binding Source={StaticResource SplitterWidth}}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="leftPanel" Grid.Column="0" Background="Beige">
                <Expander x:Name="stimulusPanel" IsExpanded="False">
                    <Expander.Header>
                        <Border BorderBrush="{StaticResource EdgeBrush}"
                                BorderThickness="{StaticResource EdgeThickness}">
                            <TextBlock Background="{StaticResource HeaderBrush}" Text="Stimulus Objects"
                                       HorizontalAlignment="{Binding HorizontalAlignment,
                                                    RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                    Mode=OneWayToSource}"/>
                        </Border>
                    </Expander.Header>
                    <Expander.Content>
                        <Grid Background="AliceBlue" Height="{StaticResource PanelHeight}">
                            
                        </Grid>
                    </Expander.Content>
                </Expander>

                <Expander x:Name="regionsPanel" IsExpanded="False">
                    <Expander.Header>
                        <Border BorderBrush="{StaticResource EdgeBrush}"
                                BorderThickness="{StaticResource EdgeThickness}">
                            <TextBlock Background="{StaticResource HeaderBrush}" Text="Stimulus Regions"
                                       HorizontalAlignment="{Binding HorizontalAlignment,
                                                    RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                    Mode=OneWayToSource}"/>
                        </Border>
                    </Expander.Header>
                    <Expander.Content>
                        <Grid Background="AliceBlue" Height="{StaticResource PanelHeight}">

                        </Grid>
                    </Expander.Content>
                </Expander>
            </StackPanel>
            <GridSplitter Grid.Column="1" Background="{StaticResource EdgeBrush}"
                          Width="{Binding Source={StaticResource SplitterWidth}}"
                          HorizontalAlignment="Stretch" />
                <DockPanel x:Name="midPanel" Grid.Column="2" Background="Bisque">

            </DockPanel>
            <GridSplitter Grid.Column="3" Background="{StaticResource EdgeBrush}"
                          Width="{Binding Source={StaticResource SplitterWidth}}"
                          HorizontalAlignment="Stretch" />
            <Grid x:Name="rightGrid" Grid.Column="4" Background="Wheat">
                
            </Grid>
        </Grid>
    </Border>
</Window>
