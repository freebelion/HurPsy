<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">
    
    <!-- Named dimension values -->
    <Thickness x:Key="EdgeThickness">2,2,2,2</Thickness>
    <GridLength x:Key="DesignPanelWidth">300</GridLength>
    <System:Double x:Key="Expander1Width">300</System:Double>
    <System:Double x:Key="Expander2Width">300</System:Double>
    <System:Double x:Key="CollapsedWidth">32</System:Double>
    <System:Double x:Key="SplitterWidth">2</System:Double>
    
    <!-- Named brush definitions -->
    <SolidColorBrush x:Key="EdgeBrush" Color="#555555"/>
    <SolidColorBrush x:Key="StimulusObjectsPanelBrush" Color="#cccccc"/>
    <SolidColorBrush x:Key="StimulusRegionsPanelBrush" Color="#dddddd"/>
    <SolidColorBrush x:Key="DesignPanelBrush" Color="#ffffff"/>
    <SolidColorBrush x:Key="PreviewPanelBrush" Color="#eeeeee"/>
    
</ResourceDictionary>