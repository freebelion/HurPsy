<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <System:Double x:Key="PanelWidth">250</System:Double>
    <System:Double x:Key="PanelHeight">350</System:Double>
    <System:Double x:Key="SplitterWidth">5</System:Double>
    <Thickness x:Key="EdgeThickness">5</Thickness>
    
    <!-- Named brush definitions -->
    <SolidColorBrush x:Key="EdgeBrush" Color="#555555"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#cccccc"/>
    <SolidColorBrush x:Key="HeaderBrush" Color="#eeeeee"/>

</ResourceDictionary>